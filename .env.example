# =============================================================================
# AI Consultants v2.10.0 - Environment Variables
# =============================================================================
# Copy this file to .env and customize as needed.
# All variables have sensible defaults - only override what you need.
#
# IMPORTANT: At least 2 consultants must be enabled for the system to work.
#
# Export variables before running, or source this file:
#   source .env && ./scripts/consult_all.sh "Your question"
#
# For detailed setup instructions, see: docs/SETUP.md

# =============================================================================
# API KEYS & AUTHENTICATION
# =============================================================================
# Each CLI tool requires its own authentication. Set the appropriate API keys
# or use the CLI's built-in auth flow.

# Google Gemini API Key
# Get yours at: https://makersuite.google.com/app/apikey
# Alternative: Run 'gemini auth login' for OAuth
# GOOGLE_API_KEY=your-google-api-key

# OpenAI API Key (required for Codex)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key

# Mistral API Key
# Get yours at: https://console.mistral.ai/api-keys/
# MISTRAL_API_KEY=your-mistral-api-key

# Anthropic API Key (for Claude API mode or synthesis)
# Get yours at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Amp API Key (for Amp CLI authentication)
# AMP_API_KEY=your-amp-api-key

# =============================================================================
# API-BASED CONSULTANT KEYS
# =============================================================================
# These are required for the API-based consultants (Qwen3, GLM, Grok, DeepSeek)

# Qwen3 (Alibaba DashScope) - The Analyst
# Get yours at: https://dashscope.console.aliyun.com/
# QWEN3_API_KEY=your_dashscope_api_key

# GLM (Zhipu AI) - The Methodologist
# Get yours at: https://open.bigmodel.cn/
# GLM_API_KEY=your_zhipu_api_key

# Grok (xAI) - The Provocateur
# Get yours at: https://console.x.ai/
# GROK_API_KEY=your_xai_api_key

# DeepSeek - The Code Specialist
# Get yours at: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=your_deepseek_api_key

# MiniMax - The Pragmatic Optimizer (v2.10)
# Get yours at: https://platform.minimax.io/user-center/basic-information/interface-key
# MINIMAX_API_KEY=your_minimax_api_key

# =============================================================================
# ENABLED CONSULTANTS
# =============================================================================
# Set to "false" to disable a consultant you haven't configured.
# MINIMUM 2 consultants must be enabled for comparison/voting to work.

# CLI-based consultants (default: enabled)
ENABLE_GEMINI=true
ENABLE_CODEX=true
ENABLE_MISTRAL=true
ENABLE_KILO=true
ENABLE_CURSOR=true
ENABLE_AIDER=false
ENABLE_AMP=false             # Amp Code (v2.8)
ENABLE_CLAUDE=false          # Auto-disabled when invoked by Claude Code

# API-based consultants (default: disabled - require API keys)
ENABLE_QWEN3=false
ENABLE_GLM=false
ENABLE_GROK=false
ENABLE_DEEPSEEK=false
ENABLE_MINIMAX=false

# Local model support via Ollama (disabled by default)
ENABLE_OLLAMA=false

# =============================================================================
# CLI/API MODE SWITCHING (v2.6+)
# =============================================================================
# 5 agents support switching: Gemini, Codex, Claude, Mistral, Qwen3
# When API mode is enabled, CLI mode is automatically disabled.

GEMINI_USE_API=false         # Use Google AI API instead of gemini CLI
CODEX_USE_API=false          # Use OpenAI API instead of codex CLI
CLAUDE_USE_API=false         # Use Anthropic API instead of claude CLI
MISTRAL_USE_API=false        # Use Mistral API instead of vibe CLI
QWEN3_USE_API=false          # Use qwen CLI (default) or DashScope API (v2.7)

# API endpoints (override if using custom endpoints)
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
# CODEX_API_URL=https://api.openai.com/v1/chat/completions
# CLAUDE_API_URL=https://api.anthropic.com/v1/messages
# MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
# QWEN3_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation

# =============================================================================
# MODEL CONFIGURATION (March 2026 premium defaults)
# =============================================================================

# Gemini - The Architect
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_TIMEOUT=180
GEMINI_CMD=gemini

# Codex - The Pragmatist
CODEX_MODEL=gpt-5.3-codex
CODEX_TIMEOUT=180
CODEX_CMD=codex

# Mistral Vibe - The Devil's Advocate
MISTRAL_MODEL=mistral-large-3
MISTRAL_TIMEOUT=180
MISTRAL_CMD=vibe

# Kilo - The Innovator
KILO_MODEL=auto
KILO_TIMEOUT=180
KILO_WORKSPACE=
KILO_CMD=kilocode

# Cursor - The Integrator
CURSOR_MODEL=composer-1.5
CURSOR_TIMEOUT=180
CURSOR_CMD=agent

# Aider - The Pair Programmer
AIDER_MODEL=gpt-5.3-codex
AIDER_TIMEOUT=180
AIDER_CMD=aider

# Amp - The Systems Thinker (v2.8)
AMP_TIMEOUT=180
AMP_CMD=amp

# Claude - The Synthesizer
CLAUDE_MODEL=opus-4.6
CLAUDE_TIMEOUT=240
CLAUDE_CMD=claude

# Qwen3 - The Analyst (CLI/API switchable v2.7)
QWEN3_MODEL=qwen3.5-plus
QWEN3_TIMEOUT=180
QWEN3_CMD=qwen

# =============================================================================
# API-BASED CONSULTANT CONFIGURATION
# =============================================================================

# GLM - The Methodologist
GLM_MODEL=glm-5
GLM_TIMEOUT=180
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# Grok - The Provocateur
GROK_MODEL=grok-4-1-fast-reasoning
GROK_TIMEOUT=180
GROK_API_URL=https://api.x.ai/v1/chat/completions

# DeepSeek - The Code Specialist
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_TIMEOUT=180
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# MiniMax - The Pragmatic Optimizer (v2.10)
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT=180
MINIMAX_API_URL=https://api.minimax.io/v1/chat/completions

# =============================================================================
# OLLAMA CONFIGURATION (Local models)
# =============================================================================

OLLAMA_MODEL=qwen2.5-coder:32b
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=300
OLLAMA_TEMPERATURE=0.7

# =============================================================================
# FEATURES v2.8
# =============================================================================

# Personas: specialized roles for each consultant
ENABLE_PERSONA=true

# Auto-synthesis: automatic synthesis of all responses
ENABLE_SYNTHESIS=true
SYNTHESIS_CMD=claude

# Multi-Agent Debate (MAD): cross-critique rounds
ENABLE_DEBATE=false
DEBATE_ROUNDS=1              # 1 = no debate, 2-3 = with cross-critique

# Self-Reflection (experimental): generate-critique-refine loop
ENABLE_REFLECTION=false
REFLECTION_CYCLES=1

# Peer Review: anonymous evaluation
ENABLE_PEER_REVIEW=false

# Panic Mode: auto-rigor when uncertainty detected
ENABLE_PANIC_MODE=auto
PANIC_CONFIDENCE_THRESHOLD=5
PANIC_EXTRA_DEBATE_ROUNDS=1

# =============================================================================
# SEMANTIC CACHING (v2.3)
# =============================================================================

ENABLE_SEMANTIC_CACHE=true
CACHE_TTL_HOURS=24
CACHE_DIR=/tmp/ai_consultants_cache

# =============================================================================
# BUDGET ENFORCEMENT (v2.4, opt-in)
# =============================================================================

ENABLE_BUDGET_LIMIT=false
BUDGET_ACTION=warn           # warn or stop
MAX_SESSION_COST=1.00

# =============================================================================
# SMART ROUTING
# =============================================================================

# Question classification (required for smart routing)
ENABLE_CLASSIFICATION=true
CLASSIFICATION_MODE=pattern  # pattern (fast) or llm (accurate)

# Smart routing: select consultants based on question category
ENABLE_SMART_ROUTING=false
MIN_AFFINITY=7               # Minimum affinity score (1-10) to include

# Cost-aware routing (v2.3)
ENABLE_COST_AWARE_ROUTING=false

# =============================================================================
# COST MANAGEMENT
# =============================================================================

ENABLE_COST_TRACKING=true
WARN_AT_COST=0.50            # Warning threshold (USD)
COST_TRACKING_FILE=/tmp/ai_consultants_costs.json

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

SESSION_DIR=/tmp/ai_consultants_sessions
SESSION_CLEANUP_DAYS=7       # Auto-cleanup sessions older than N days

# =============================================================================
# INTERACTIVE MODE
# =============================================================================

ENABLE_PROGRESS_BARS=true    # Show progress bars during consultation
ENABLE_EARLY_TERMINATION=true # Allow Ctrl+C to stop with partial results

# =============================================================================
# PRE-FLIGHT CHECKS
# =============================================================================

ENABLE_PREFLIGHT=false       # Run health check before each consultation
PREFLIGHT_QUICK=true         # Quick mode: CLI check only, skip API test

# =============================================================================
# RETRY & TIMEOUT
# =============================================================================

MAX_RETRIES=2                # Max retry attempts on failure
RETRY_DELAY_SECONDS=5        # Pause between retries

# Output directory base
DEFAULT_OUTPUT_DIR_BASE=/tmp/ai_consultations

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO               # DEBUG, INFO, WARN, ERROR
